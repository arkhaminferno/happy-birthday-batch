# Optional: path to your ACE-Step-1.5 checkout (for audio generation).
# If unset, the batch tools look for ../ACE-Step-1.5 next to this repo.
# ACESTEP_ROOT=/path/to/ACE-Step-1.5

# Force LLM on at API startup (recommended for RTX 5070 / 16GB+ VRAM).
# ACESTEP_INIT_LLM=true

# Override After Effects paths if installed in a non-default location (Windows).
# AERENDER_PATH=C:\Program Files\Adobe\Adobe After Effects 2025\Support Files\aerender.exe
# AFTERFX_COM_PATH=C:\Program Files\Adobe\Adobe After Effects 2025\Support Files\AfterFX.com
